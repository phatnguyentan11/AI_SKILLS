#!/usr/bin/env sh

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$ROOT" ]; then
  echo "[governance][warning] Cannot resolve repository root. Skipping local pre-push checks."
  exit 0
fi

GOVERNANCE_SCRIPT="$ROOT/.github/scripts/pre-push-governance-check.ps1"
FORMAT_SCRIPT="$ROOT/.github/scripts/format-staged-files.ps1"

STATUS=0

run_ps() {
  SCRIPT_FILE="$1"
  shift
  if command -v pwsh >/dev/null 2>&1; then
    pwsh -NoProfile -File "$SCRIPT_FILE" "$@"
  elif command -v powershell >/dev/null 2>&1; then
    powershell -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT_FILE" "$@"
  else
    echo "[warning] PowerShell not available. Skipping: $SCRIPT_FILE"
    return 0
  fi
}

# ── 1. Format check on pushed files (warn only, no auto-fix after commit) ────
if [ -f "$FORMAT_SCRIPT" ]; then
  run_ps "$FORMAT_SCRIPT" -Mode PrePush
fi

# ── 2. Governance check ───────────────────────────────────────────────────────
if [ -f "$GOVERNANCE_SCRIPT" ]; then
  run_ps "$GOVERNANCE_SCRIPT" -Mode Warn
  STATUS=$?
else
  echo "[governance][warning] Missing $GOVERNANCE_SCRIPT. Skipping governance checks."
fi

# Warning hook by default: never blocks git push.
# To enforce locally during push, set AI_GOVERNANCE_STRICT=1.
case "$AI_GOVERNANCE_STRICT" in
  1|true|TRUE|yes|YES)
    exit "$STATUS"
    ;;
esac

exit 0
