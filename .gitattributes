# Normalize line endings for all text files
* text=auto

# Force LF for shell scripts and git hooks (must not have CRLF on Windows)
.github/hooks/* text eol=lf
*.sh text eol=lf

# Force LF for markdown/yaml/json
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ps1 text eol=crlf

# Binary files - no line ending conversion
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
